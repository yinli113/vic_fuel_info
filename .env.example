# Copy to .env and fill in. Never commit .env.

# Database (required for app + ingestion) — pick ONE style:
#
# A) Single URL (encode special chars in password, e.g. @ → %40)
POSTGRES_DB_URL=postgresql://user:pass@host:5432/dbname
#
# B) Discrete vars (good for Streamlit Secrets: no URL-encoding of password)
# POSTGRES_HOST=aws-1-ap-south-1.pooler.supabase.com
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres.your_project_ref
# POSTGRES_PASSWORD=your_plain_database_password
# POSTGRES_DBNAME=postgres
# POSTGRES_SSLMODE=require

# Servo Saver / Fair Fuel API (required for ingestion)
SERVO_SAVER_API_CONSUMER_ID=your_consumer_id

# Optional: Fuel Up Plan auto-refresh (seconds). 0 = off. Needs Streamlit ≥1.33 (st.fragment).
# STREAMLIT_AUTO_REFRESH_SECONDS=300

# Optional: AI report on Data Analysis page (Gemini preferred if both set)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_REPORT_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=
# AI_REPORT_PROVIDER=gemini
