# Copy to .env and fill in. Never commit .env.

# Database (required for app + ingestion)
POSTGRES_DB_URL=postgresql://user:pass@host:5432/dbname

# Servo Saver / Fair Fuel API (required for ingestion)
SERVO_SAVER_API_CONSUMER_ID=your_consumer_id

# Optional: AI report on Data Analysis page (Gemini preferred if both set)
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GEMINI_REPORT_MODEL=gemini-2.5-flash
# OPENAI_API_KEY=
# AI_REPORT_PROVIDER=gemini
